# iToolkit Configuration

# Path where the full iPhone backup will be stored
IPHONE_BACKUP_PATH="/path/to/your/backups/iPhone_Backup"

# (Optional) Specific iPhone UDID. If empty, it will auto-detect the first connected device.
IPHONE_UDID=""

# Path where photos will be imported and organized
PHOTO_DESTINATION="/path/to/your/photos"

# Mount point for the iPhone filesystem (using ifuse)
IPHONE_MOUNT_POINT="/path/to/your/mount_point/mnt"
